# Tanit Frontend — Local Development
# Copy to .env.local and fill in required values

# ── Content & Config ──
ENVIRONMENT=local
CONTENT_ROOT=/app/content
PERMISSIONS_CONFIG=/app/content/permissions.json

# ── Data Sources (REQUIRED — no defaults) ──
DUCKDB_GCS_URL=gs://dashboard-example/analyte_health/dashboard.duckdb
DUCKDB_GCS_CREDENTIALS=/app/secrets/gcs-credentials.json
DUCKDB_LOCAL_PATH=/app/data/dashboard.duckdb

# ── Authentication (REQUIRED — no default) ──
CLERK_PUBLISHABLE_KEY=

# ── Logging ──
LOG_LEVEL=DEBUG
LOG_FORMAT=text
LOG_FILE_PATH=/app/logs/app.log

# ── Event Logging ──
EVENT_LOG_BACKEND=local
EVENT_LOG_DIR=/app/data/events
# EVENT_LOG_GCS_BUCKET=
# EVENT_LOG_GCS_PREFIX=events
# EVENT_LOG_GCS_CREDENTIALS=/app/secrets/gcs-credentials.json
# EVENT_LOG_FLUSH_INTERVAL=10.0
# EVENT_LOG_FLUSH_SIZE=524288

# ── Runtime ──
USAGE_DB_PATH=/app/data/usage.db
CHAT_DB_PATH=/app/data/chat_logs.db
RATE_LIMIT_PER_USER=60
RATE_LIMIT_GLOBAL=500
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:5173
